# OpenAI 兼容 API 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 豆瓣 API 配置
DOUBAN_API_KEY=your_douban_api_key_here

# 安全配置
SESSION_SECRET_KEY=your_random_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Redis 配置
REDIS_URL=redis://localhost:6379

# 数据库配置
# SQLite (默认,开发环境使用) - 默认会自动使用 backend/book_agent.db
# 如需自定义路径，使用绝对路径避免工作目录问题
# DATABASE_URL=sqlite+aiosqlite:///D:/work2/book_agent/backend/book_agent.db
# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookagent

# 并发控制配置
MAX_CONCURRENT_REQUESTS=50
MAX_LLM_CONCURRENT=10
MAX_LLM_QPS=5
MAX_MEMORY_PERCENT=80.0

# 环境
ENV=development

# 日志级别
LOG_LEVEL=INFO
