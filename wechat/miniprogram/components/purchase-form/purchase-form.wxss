/* components/purchase-form/purchase-form.wxss */
.purchase-form-container {
  padding: 24rpx;
  background: white;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.form-section {
  background: white;
  border-radius: 8rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-value {
  font-size: 28rpx;
  color: #666;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
}

.form-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  border: 1rpx solid #e0e0e0;
}

.form-textarea {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  border: 1rpx solid #e0e0e0;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #1677ff;
  border: none;
}

.submit-btn::after {
  border: none;
}
