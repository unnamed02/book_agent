/* components/books-not-found/books-not-found.wxss */
.books-not-found-container {
  margin-top: 24rpx;
}

.not-found-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: normal;
}

.books-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.book-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  gap: 16rpx;
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.book-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.book-author {
  font-size: 22rpx;
  color: #666;
}

.recommend-link {
  flex-shrink: 0;
  color: #1890ff;
  font-size: 24rpx;
}

.toggle-btn {
  text-align: center;
  font-size: 24rpx;
  color: #1890ff;
  padding: 0;
}
