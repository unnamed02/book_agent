<!--index.wxml-->
<navigation-bar title="AI馆员" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<!-- 新会话按钮 -->
<view wx:if="{{messages.length > 0}}" class="new-session-btn" bindtap="startNewSession">
  <text class="new-session-icon">+</text>
  <text class="new-session-text">新会话</text>
</view>

<view class="chat-container">
  <!-- 消息列表 -->
  <scroll-view
    class="messages-scroll"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="{{true}}"
    bindscroll="onScroll"
    bindscrolltolower="onScrollToLower"
    lower-threshold="50"
  >
    <!-- 空状态 -->
    <view wx:if="{{messages.length === 0}}" class="empty-state">
      <image class="empty-icon-img" src="../../images/bg.png" mode="aspectFit"></image>
      <view class="empty-title">您好！我是碑林区图书馆AI馆员</view>
      <view class="empty-desc">告诉我您想读什么类型的书，我会为您推荐</view>
    </view>

    <!-- 消息列表 -->
    <view wx:else class="messages-list">
      <view
        wx:for="{{messages}}"
        wx:key="index"
        class="message-item"
        id="msg-{{index}}"
      >
        <!-- 用户消息 -->
        <view wx:if="{{item.role === 'user'}}" class="message-user">
          <view class="message-content user-content">
            <text>{{item.content}}</text>
          </view>
        </view>

        <!-- 助手消息 -->
        <view wx:else class="message-assistant">
          <view class="message-content assistant-content">
            <!-- 思考过程 -->
            <view wx:if="{{item.thinkingContent}}" class="thinking-container">
              <view class="thinking-content">
                <text>{{item.thinkingContent}}</text>
              </view>
            </view>

            <!-- 普通 Markdown 内容 -->
            <markdown wx:if="{{item.content}}" content="{{item.content}}" searchResults="{{item.searchResults || []}}" />

            <!-- 搜索结果 -->
            <view wx:if="{{item.searchResults && item.searchResults.length > 0}}" class="search-results-container">
              <view class="search-results-header">
                <text class="search-results-title">已阅读 {{item.searchResults.length}} 个页面</text>
              </view>
              <view class="search-results-list">
                <view wx:for="{{item.searchResults}}" wx:for-item="result" wx:key="index" class="search-result-item" bindtap="onSearchResultTap" data-url="{{result.url}}" data-title="{{result.title}}">
                  <text class="search-result-index">[{{result.index}}]</text>
                  <text class="search-result-title">{{result.title}}</text>
                </view>
              </view>
            </view>

            <!-- 书籍卡片 -->
            <book-card wx:if="{{item.type === 'book_cards' && item.books}}" books="{{item.books}}" bind:recommend="onRecommend" />

            <!-- 追加内容 -->
            <markdown wx:if="{{item.appendContent}}" content="{{item.appendContent}}" searchResults="{{item.searchResults || []}}" />

            <!-- 未找到的书籍 -->
            <books-not-found wx:if="{{item.booksNotFound && item.booksNotFound.length > 0}}" books="{{item.booksNotFound}}" bind:recommend="onRecommend" />

            <!-- 荐购表单 -->
            <purchase-form
              wx:if="{{item.type === 'purchase_form'}}"
              title="{{item.purchaseTitle}}"
              author="{{item.purchaseAuthor}}"
              bind:submit="onPurchaseSubmit"
            />
          </view>
        </view>
      </view>

      <!-- 加载状态 -->
      <view wx:if="{{loading}}" class="message-item">
        <view class="message-assistant">
          <view class="message-content assistant-content loading-content">
            <view class="loading-dots">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
            <text class="loading-text">正在思考...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-wrapper">
      <textarea
        class="input-box"
        value="{{input}}"
        placeholder="输入消息..."
        placeholder-class="placeholder-style"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
        disabled="{{loading}}"
        auto-height
        fixed
        disable-default-padding
        maxlength="500"
        cursor-spacing="20"
      />
    </view>
    <view class="btn-wrapper">
      <button
        class="btn-send {{canSend ? 'btn-send-active' : ''}}"
        bindtap="sendMessage"
        disabled="{{!canSend || loading}}"
        hover-class="btn-hover"
      >
        发送
      </button>
    </view>
  </view>
</view>
